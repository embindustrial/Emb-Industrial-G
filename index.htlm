<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EMB Industrial Group</title>
    <!-- Tipografía premium -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">
    <style>
        body {
            margin: 0;
            font-family: 'Roboto', sans-serif;
            background-color: #f5f5f5;
            color: #333;
        }

        /* Header y navegación */
        header {
            background-color: #0d1b2a;
            color: white;
            padding: 15px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 100;
        }
        header h1 {
            margin: 0;
            font-size: 1.8rem;
        }
        nav a {
            color: white;
            text-decoration: none;
            margin-left: 20px;
            font-weight: 500;
        }
        nav a:hover {
            color: #fca311;
        }

        /* Banner principal */
        .banner {
            width: 100%;
            max-height: 450px;
            overflow: hidden;
        }
        .banner img {
            width: 100%;
            height: auto;
            display: block;
        }

        /* Productos */
        .productos {
            display: flex;
            flex-wrap: wrap;
            justify-content: center;
            margin: 30px 20px;
            gap: 20px;
        }
        .productos img {
            width: 300px;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            transition: transform 0.3s, box-shadow 0.3s;
        }
        .productos img:hover {
            transform: scale(1.05);
            box-shadow: 0 8px 20px rgba(0,0,0,0.3);
        }

        /* Botón WhatsApp */
        .whatsapp-btn {
            position: fixed;
            bottom: 20px;
            right: 20px;
            background-color: #25D366;
            color: white;
            border: none;
            padding: 15px 20px;
            border-radius: 50px;
            font-size: 1rem;
            text-decoration: none;
            box-shadow: 0 4px 8px rgba(0,0,0,0.2);
            z-index: 1000;
        }
        .whatsapp-btn:hover {
            background-color: #1ebe5d;
        }

        /* Footer */
        footer {
            background-color: #0d1b2a;
            color: white;
            text-align: center;
            padding: 25px 20px;
            margin-top: 40px;
        }
        footer p {
            margin: 5px 0;
        }
        footer a {
            color: #fca311;
            text-decoration: none;
        }
        footer a:hover {
            text-decoration: underline;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .productos {
                flex-direction: column;
                align-items: center;
            }
            nav a {
                margin-left: 10px;
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header>
        <h1>EMB Industrial Group</h1>
        <nav>
            <a href="#inicio">Inicio</a>
            <a href="#productos">Productos</a>
            <a href="#contacto">Contacto</a>
        </nav>
    </header>

    <!-- Banner -->
    <div class="banner">
        <img src="imagenes/banner1.jpeg" alt="Banner EMB Industrial Group">
    </div>

    <!-- Productos -->
    <section id="productos" class="productos">
        <img src="imagenes/producto1.jpeg" alt="Producto 1">
        <img src="imagenes/producto2.jpeg" alt="Producto 2">
        <img src="imagenes/producto3.jpeg" alt="Producto 3">
        <img src="imagenes/producto4.jpeg" alt="Producto 4">
    </section>

    <!-- Botón WhatsApp -->
    <a href="https://wa.me/593995182911" target="_blank" class="whatsapp-btn">WhatsApp</a>

    <!-- Footer -->
    <footer>
        <p>EMB Industrial Group - Soluciones industriales con eficiencia y confianza</p>
        <p>Repuestos, servicio técnico y accesorios para bordadoras industriales</p>
        <p>Contáctanos: <a href="mailto:ventas@embindustrial.com">ventas@embindustrial.com</a> | +593 995182911</p>
        <p>www.embindustrial.com</p>
    </footer>
</body>
</html>
